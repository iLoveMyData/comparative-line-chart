{
  "dataRoles": [
    {
      "name": "category",
      "kind": "Grouping",
      "displayName": "Period",
      "displayNameKey": "Role_Category"
    },
    {
      "name": "actual",
      "kind": "Measure",
      "displayName": "Series A (auto-cumulated)",
      "displayNameKey": "Role_Actual",
      "requiredTypes": [{ "numeric": true }, { "integer": true }]
    },
    {
      "name": "forecast",
      "kind": "Measure",
      "displayName": "Series B (auto-cumulated)",
      "displayNameKey": "Role_Forecast",
      "requiredTypes": [{ "numeric": true }, { "integer": true }]
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        {
          "category": { "max": 1 },
          "actual":   { "max": 1 },
          "forecast": { "max": 1 }
        }
      ],
      "categorical": {
        "categories": {
          "for": { "in": "category" },
          "dataReductionAlgorithm": { "top": { "count": 1000 } }
        },
        "values": {
          "select": [
            { "bind": { "to": "actual"   } },
            { "bind": { "to": "forecast" } }
          ]
        }
      }
    }
  ],
  "objects": {
